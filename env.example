# paige — environment variable template.
#
# Copy this file to ~/.paige/.env and fill in your Feishu credentials.
# `prod.sh start` sources ~/.paige/.env into the launched process
# environment, so anything in here becomes a real env var for paige.
#
# Required keys are marked REQUIRED. Optional keys carry their
# default value as a comment so you only need to override what you
# want changed.


# ── Feishu credentials ──────────────────────────────────────────

# Open-Feishu App ID — REQUIRED.
# Find it at: https://open.feishu.cn → Apps → your app → Credentials.
PAIGE_FEISHU_APP_ID=

# Open-Feishu App Secret — REQUIRED.
PAIGE_FEISHU_APP_SECRET=

# Domain override. Default: https://open.feishu.cn (mainland).
# Use https://open.larksuite.com for Lark International.
# PAIGE_FEISHU_DOMAIN=

# Topic-mode group. When set to a topic-mode group's chat_id
# (`oc_…`), the operator has opted into pane-per-topic routing:
# each Lark topic in this group binds to its own pane. Create the
# group manually with `chat_mode=group` + `group_message_type=thread`
# (Lark calls it "话题模式群" — topic mode group). Paige doesn't
# gate behavior on this — bindings just key on whatever topic_id
# the parser reports per inbound — but setting it makes operator
# intent discoverable and gets logged at startup.
# PAIGE_FEISHU_GROUP_ID=oc_xxx


# ── Access control ──────────────────────────────────────────────

# Comma-separated list of user_ids allowed to talk to the bot.
# Empty (default) = open to anyone the bot can hear from. Strongly
# recommended to set this once you've identified your user_id (paige
# logs each inbound's sender.user_id, so check `~/.paige/paige.log`
# after sending a test message).
# PAIGE_ALLOWED_USERS=ou_abc123,ou_def456

# Comma-separated list of user_ids allowed to run admin commands
# (currently just /server). Empty (default) = every allowed user is
# admin — fine for solo deploys.
# PAIGE_ADMIN_USERS=ou_abc123


# ── Filesystem layout ───────────────────────────────────────────

# State directory — paige.log, paige.pid, run_registry.json,
# message_seq.json, jsonl_watcher_state.json, .env, venv/, wheels/.
# Default: ~/.paige
# PAIGE_DIR=~/.paige

# Root directory whose immediate subdirectories show up in /start's
# directory picker AND the /sessions → 🆕 New sub-pane. Default:
# ~/projects.
# PAIGE_PROJECTS_ROOT=~/projects


# ── Tmux ────────────────────────────────────────────────────────

# Default tmux session name new panes spawn into. Default: paige.
# PAIGE_TMUX_SESSION=paige


# ── Polling intervals ───────────────────────────────────────────

# How often the status spinner card scrapes claude's TUI for verb
# changes. Lower = snappier card updates, higher = less CPU.
# Default: 1.0 (seconds).
# PAIGE_STATUS_INTERVAL=1.0

# How often the JSONL watcher polls claude's transcript files for
# new events. Default: 2.0 (seconds).
# PAIGE_WATCHER_INTERVAL=2.0


# ── Voice transcription (optional) ─────────────────────────────

# When set, voice notes attached to inbounds get transcribed via the
# OpenAI audio API and the text body is forwarded to claude. Feishu
# transcribes client-side, so this is rarely needed on a Feishu-only
# deploy — left in for completeness.
# PAIGE_OPENAI_API_KEY=sk-...

# Override base URL — useful for OpenAI-compatible proxies.
# Default: https://api.openai.com/v1.
# PAIGE_OPENAI_BASE_URL=https://api.openai.com/v1
